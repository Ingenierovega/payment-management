        {
          "name": "03 - Listar proveedores con paginacion y filtro por estado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200 OK', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Respuesta paginada', function () {",
                  "  pm.expect(json).to.have.property('content');",
                  "  pm.expect(json).to.have.property('page');",
                  "  pm.expect(json).to.have.property('size');",
                  "  pm.expect(json.content).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/suppliers?status=ACTIVO&page=0&size=10&sort=businessName,asc",
