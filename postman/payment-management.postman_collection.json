    {
      "name": "Bloque 1 - Gestion de proveedores",
      "description": "Criterios 1 a 5: crear, listar, consultar, actualizar y cambiar estado de proveedores.",
      "item": [
        {
          "name": "01 - Crear proveedor activo",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = `${Date.now()}-${Math.floor(Math.random() * 10000)}`;",
                  "pm.collectionVariables.set('runSuffix', suffix);",
                  "pm.collectionVariables.set('activeSupplierTax', `NIT-ACT-${suffix}`);",
                  "pm.collectionVariables.set('activeSupplierEmail', `activo.${suffix}@example.com`);",
                  "pm.collectionVariables.set('inactiveSupplierTax', `NIT-INACT-${suffix}`);",
                  "pm.collectionVariables.set('inactiveSupplierEmail', `inactivo.${suffix}@example.com`);",
                  "pm.collectionVariables.set('updatedSupplierTax', `NIT-UPD-${suffix}`);",
                  "pm.collectionVariables.set('updatedSupplierEmail', `actualizado.${suffix}@example.com`);",
                  "pm.collectionVariables.set('idempotencyKey', `order-key-${suffix}`);",
                  "pm.collectionVariables.set('invalidOrderKey', `invalid-order-key-${suffix}`);",
                  "pm.collectionVariables.set('rejectedOrderKey', `rejected-order-key-${suffix}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 201 Created', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('supplierId', json.id);",
                  "pm.test('Proveedor queda ACTIVO', function () { pm.expect(json.status).to.eql('ACTIVO'); });",
                  "pm.test('NIT corresponde al enviado', function () { pm.expect(json.taxIdentificationNumber).to.eql(pm.collectionVariables.get('activeSupplierTax')); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"Proveedor Activo {{runSuffix}}\",\n  \"taxIdentificationNumber\": \"{{activeSupplierTax}}\",\n  \"email\": \"{{activeSupplierEmail}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/suppliers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "suppliers"
              ]
            }
          }
        },
        {
          "name": "02 - Rechazar proveedor con NIT duplicado",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 409 Conflict', function () { pm.response.to.have.status(409); });",
                  "const json = pm.response.json();",
                  "pm.test('Respuesta de error descriptiva', function () {",
                  "  pm.expect(json.status).to.eql(409);",
                  "  pm.expect(json.message).to.include('numero tributario');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"Proveedor Duplicado {{runSuffix}}\",\n  \"taxIdentificationNumber\": \"{{activeSupplierTax}}\",\n  \"email\": \"duplicado.{{runSuffix}}@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
